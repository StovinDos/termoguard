# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.

# Backend API base URL
# - Local development: http://localhost:8080/api  (proxied via Vite to /api)
# - Production:        https://api.termoguard.io/api
VITE_API_BASE_URL=/api

# GitHub Pages deployment sub-path (leave blank for root / custom domain)
# Example: /termoguard  (if hosted at https://your-org.github.io/termoguard)
VITE_BASE_PATH=/
