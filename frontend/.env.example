# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.

# Backend API base URL
# - Local development: /api  (proxied via Vite to http://localhost:8080)
# - Production:        https://termoguard-production.up.railway.app/api
# IMPORTANT: always use an absolute URL (starting with https://) for production
# to avoid the value being treated as a relative path by the browser.
VITE_API_BASE_URL=https://termoguard-production.up.railway.app/api

# GitHub Pages deployment sub-path (leave blank for root / custom domain)
# Example: /termoguard  (if hosted at https://your-org.github.io/termoguard)
VITE_BASE_PATH=/

# Google reCAPTCHA v2 site key
# Register at https://www.google.com/recaptcha/admin and choose "reCAPTCHA v2 / I'm not a robot".
# When this variable is set, the CAPTCHA widget is shown on the registration and enterprise
# inquiry forms, and users must pass it before the form can be submitted.
# Leave blank (or omit) to disable CAPTCHA during local development.
VITE_RECAPTCHA_SITE_KEY=
